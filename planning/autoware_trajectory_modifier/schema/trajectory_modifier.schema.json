{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Parameters for Trajectory Modifier",
  "type": "object",
  "definitions": {
    "trajectory_modifier": {
      "type": "object",
      "properties": {
        "use_stop_point_fixer": {
          "type": "boolean",
          "description": "Enable the stop point fixer modifier plugin",
          "default": true
        },
        "stop_point_fixer": {
          "type": "object",
          "properties": {
            "force_stop_long_stopped_trajectories": {
              "type": "boolean",
              "description": "Force zero velocity trajectory for trajectories with long stops",
              "default": true
            },
            "force_stop_close_stopped_trajectories": {
              "type": "boolean",
              "description": "Force zero velocity trajectory for trajectories with stops close to ego",
              "default": true
            },
            "velocity_threshold_mps": {
              "type": "number",
              "description": "Velocity threshold below which ego vehicle is considered stationary",
              "default": 0.25,
              "minimum": 0.0
            },
            "min_distance_threshold_m": {
              "type": "number",
              "description": "Minimum distance threshold to trigger trajectory replacement",
              "default": 1.0,
              "minimum": 0.0
            },
            "min_stop_duration_s": {
              "type": "number",
              "description": "Minimum duration of stop to consider for trajectory replacement",
              "default": 0.5,
              "minimum": 0.0
            }
          },
          "required": [],
          "additionalProperties": false
        }
      },
      "required": [],
      "additionalProperties": false
    }
  },
  "properties": {
    "/trajectory_modifier": {
      "type": "object",
      "properties": {
        "ros__parameters": {
          "$ref": "#/definitions/trajectory_modifier"
        }
      },
      "required": ["ros__parameters"],
      "additionalProperties": false
    }
  },
  "required": ["/trajectory_modifier"],
  "additionalProperties": false
}
